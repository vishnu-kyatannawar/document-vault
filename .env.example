# Google OAuth Client ID (Web application).
# This value is PUBLIC by design — it ships in the client bundle. There is NO
# client secret in this app. Lock the Client ID to your origin in Google Cloud.
#
# Local dev: copy this file to `.env` and paste your Client ID below.
# Production: set as an Actions *variable* named VITE_GOOGLE_CLIENT_ID.
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
